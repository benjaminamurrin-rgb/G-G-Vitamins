{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gng",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-e",
        "const http=require('http'),fs=require('fs'),path=require('path');const root=process.cwd();http.createServer((q,s)=>{let f=q.url==='/'?'/index.html':q.url;f=path.join(root,decodeURIComponent(f.split('?')[0]));fs.readFile(f,(e,d)=>{if(e){s.writeHead(404);s.end('404');return;}const ext=path.extname(f);const t={'.html':'text/html','.js':'text/javascript','.css':'text/css'}[ext]||'application/octet-stream';s.writeHead(200,{'Content-Type':t});s.end(d);});}).listen(4321,()=>console.log('serving on 4321'));"
      ],
      "port": 4321
    }
  ]
}
